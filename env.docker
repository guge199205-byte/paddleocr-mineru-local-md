# Default Docker image tags for RTX 30 / RTX 40 and other non-Blackwell NVIDIA GPUs.
# RTX 50 / Blackwell users should use env.txt instead.
API_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-offline
VLM_BACKEND=vllm
VLM_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-offline

PANDOCR_GPU_DEVICE_ID=0
PADDLEOCR_VL_MODEL_NAME=PaddleOCR-VL-1.6-0.9B
PPOCR_V6_MODEL_NAME=PP-OCRv6_medium
UNLIMITED_OCR_MODEL_NAME=baidu/Unlimited-OCR
UNLIMITED_OCR_BACKEND=transformers
UNLIMITED_OCR_PRELOAD=1
UNLIMITED_OCR_ATTENTION_BACKEND=flashinfer
UNLIMITED_OCR_MAX_TOKENS=32768
PANDOCR_ENABLE_UNLIMITED_OCR=0
PANDOCR_MODEL_CONTROL=docker
PANDOCR_ACTIVE_MODEL_ON_START=paddleocr-vl-1.6
PANDOCR_MODEL_SWITCH_TIMEOUT=1200
PADDLE_REQUEST_TIMEOUT=3600
PANDOCR_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
PANDOCR_MAX_UPLOAD_MB=512
PANDOCR_MAX_TOTAL_UPLOAD_MB=4096
PANDOCR_DEFAULT_CHUNK_SIZE_MB=10
PANDOCR_CHUNKED_UPLOAD_THRESHOLD_MB=100
PANDOCR_MAX_BATCH_MB=200
PANDOCR_UPLOAD_TTL_HOURS=24
PANDOCR_MAX_CONCURRENT_OCR=1
PANDOCR_ENFORCE_ORIGIN_CHECK=1
PANDOCR_API_TOKEN=
PANDOCR_ENABLE_API_DOCS=0

# Translation API (OpenAI-compatible)
PANDOCR_TRANSLATE_API_URL=
PANDOCR_TRANSLATE_API_KEY=
PANDOCR_TRANSLATE_MODEL=deepseek-v4-flash

# GLM-OCR via Ollama
PANDOCR_OLLAMA_BASE_URL=http://ollama:11434
PANDOCR_OLLAMA_MODEL=glm-ocr
PANDOCR_OLLAMA_NUM_CTX=8192
PANDOCR_OLLAMA_NUM_PREDICT=4096
