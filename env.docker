# Default Docker image tags for RTX 30 / RTX 40 and other non-Blackwell NVIDIA GPUs.
# RTX 50 / Blackwell users should use env.txt instead.
API_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-offline
VLM_BACKEND=vllm
VLM_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-offline

PADDLEOCR_VL_MODEL_NAME=PaddleOCR-VL-1.6-0.9B
PADDLE_REQUEST_TIMEOUT=3600
